# ==== required ====

# Google AI Studio — Gemini 2.5 Flash for vision
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ElevenLabs — Voice Design, TTS, Sound Effects, Conversational AI
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Cloudflare R2 — images + cached audio
# Settings -> R2 -> Manage R2 API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=overheard-assets
# Optional public CDN base URL for R2 objects (r2.dev or custom domain)
R2_PUBLIC_BASE_URL=

# Postgres — local or Cloud SQL
# Local: postgres://overheard:overheard@localhost:5432/overheard
# Cloud SQL: see https://cloud.google.com/sql/docs/postgres/connect-run
DATABASE_URL=postgres://overheard:overheard@localhost:5432/overheard

# ==== optional ====

# Handle for the shared demo user row
DEMO_USER_HANDLE=demo

# Webhook secret for ElevenLabs post-conversation events
ELEVENLABS_WEBHOOK_SECRET=
